# Backend Go — variáveis de ambiente (copie para .env e ajuste)
# DB local via docker-compose (raiz do repo): docker compose up -d db
DATABASE_URL=postgres://app_role:app_secret@localhost:5432/artemise?sslmode=disable
PORT=8080
APP_ENV=dev
SESSION_TTL_H=720
ARGON2_TIME=1
ARGON2_MEMORY=65536
ARGON2_THREADS=4
